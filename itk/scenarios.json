        "current",
        "python_v10"
      ],
      "traversal": "euler",
      "edges": ["0->1", "1->0"],
      "protocols": [
        "jsonrpc",
        "grpc",
        "http_json"
      ],
      "behavior": "send_message"
    },
    {
      "name": "Current vs Python v10 - Send Message (Streaming)",
